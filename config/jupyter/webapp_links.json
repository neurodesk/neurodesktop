    },
    "sct": {
      "title": "SCT",
      "description": "Hosted Spinal Cord Toolbox web application",
      "direct_url": "https://sct.neurodesk.org/",
      "icon": "/opt/neurodesk/icons/sct.png"
    },
    "seedseg": {
      "title": "SeedSeg",
      "description": "Hosted SeedSeg web application",
      "direct_url": "https://seedseg.neurodesk.org/",
      "icon": "/opt/neurodesk/icons/seedseg.svg"

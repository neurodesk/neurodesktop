      "icon": "/opt/neurodesk/icons/calmar.svg"
    },
    "dicompare": {
      "direct_url": "https://dicompare.neurodesk.org/",
      "icon": "/opt/neurodesk/icons/dicompare.svg"
    },
    "jamovi": {
      "startup_timeout": 300,
      "path_rewrites": [
        {
          "from": "/assets/",
          "to": "${base_path}assets/"
        },
        {
          "from": "\"/version\"",
          "to": "\"${base_path}version\""
        },
        {
          "from": "\"/settings\"",
          "to": "\"${base_path}settings\""
        }
      ]
    },
    "musclemap": {
      "title": "MuscleMap",

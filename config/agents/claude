#!/bin/bash
# Claude Code wrapper script
# Copies ~/AGENTS.md and settings.local.json to current directory, then starts Claude Code

CLAUDE_DEFAULT_MCP_CONFIG="/opt/jovyan_defaults/.claude/mcp_config.json"

is_apptainer_runtime() {
    [ -n "${SINGULARITY_NAME:-}" ] || \
    [ -n "${APPTAINER_NAME:-}" ] || \
    [ -n "${APPTAINER_CONTAINER:-}" ] || \
    [ -n "${SINGULARITY_CONTAINER:-}" ] || \
    [ -n "${APPTAINER_COMMAND:-}" ] || \
    [ -n "${SINGULARITY_COMMAND:-}" ] || \
    [ -d "/.apptainer.d" ] || \
    [ -d "/.singularity.d" ]
}

load_br_mcp_token_from_bashrc() {
    local bashrc_file="${HOME}/.bashrc"
    local token_from_bashrc

    if [ -n "${BR_MCP_TOKEN:-}" ]; then
        export BR_MCP_TOKEN
        return 0
    fi

    if [ ! -f "${bashrc_file}" ]; then
        return 0
    fi

    token_from_bashrc=$(sed -nE \
        -e "s/^[[:space:]]*export[[:space:]]+BR_MCP_TOKEN='([^']+)'[[:space:]]*$/\1/p" \
        -e 's/^[[:space:]]*export[[:space:]]+BR_MCP_TOKEN="([^"]+)"[[:space:]]*$/\1/p' \
        -e 's/^[[:space:]]*export[[:space:]]+BR_MCP_TOKEN=([^[:space:]#]+)[[:space:]]*$/\1/p' \
        "${bashrc_file}" | tail -n 1)

    if [ -n "${token_from_bashrc}" ]; then
        export BR_MCP_TOKEN="${token_from_bashrc}"
    fi
}

# Neurodesktop ships a pinned Claude CLI build; auto-updates are managed
# centrally by the container image, so disable the in-process updater.
export DISABLE_AUTOUPDATER=1

# Copy AGENTS.md from home directory to current directory as CLAUDE.md
if [ ! -f ./CLAUDE.md ]; then
    cp /opt/AGENTS.md ./CLAUDE.md
fi

# Copy settings.local.json from home directory to current directory's .claude folder
if [ ! -f ./.claude/settings.local.json ]; then
    mkdir -p ./.claude
    cp /opt/jovyan_defaults/.claude/settings.local.json ./.claude/settings.local.json
fi

load_br_mcp_token_from_bashrc

if [ -n "${BR_MCP_TOKEN:-}" ]; then
    echo "Brain Researcher MCP server: ACTIVE (using BR_MCP_TOKEN from env/~/.bashrc)"
else
    echo "Brain Researcher MCP server: inactive (run 'opencode' to set BR_MCP_TOKEN)"
fi

# Keep the standard user-local path for tools that expect it, but make it a
# symlink to the image-owned Claude binary. Replacing an old persistent copy on
# every image upgrade ensures the wrapper cannot keep running a stale version,
# and avoids duplicating the ~230MB binary on network-mounted homes.
CLAUDE_BIN="${HOME}/.local/bin/claude"
DEFAULT_CLAUDE_BIN="/opt/jovyan_defaults/.local/bin/claude"

if [ ! -x "${DEFAULT_CLAUDE_BIN}" ]; then
    echo "Claude binary not found at ${DEFAULT_CLAUDE_BIN}." >&2
    exit 127
fi

CLAUDE_BIN_DIR=$(dirname "${CLAUDE_BIN}")
CLAUDE_LINK_TMP="${CLAUDE_BIN}.tmp.$$"

if mkdir -p "${CLAUDE_BIN_DIR}"; then
    if [ ! -L "${CLAUDE_BIN}" ] || [ "$(readlink "${CLAUDE_BIN}")" != "${DEFAULT_CLAUDE_BIN}" ]; then
        rm -f "${CLAUDE_LINK_TMP}"
        if ln -s "${DEFAULT_CLAUDE_BIN}" "${CLAUDE_LINK_TMP}" \
            && mv -Tf "${CLAUDE_LINK_TMP}" "${CLAUDE_BIN}"; then
            :
        else
            rm -f "${CLAUDE_LINK_TMP}"
            echo "Warning: could not link ${CLAUDE_BIN} to the image-owned Claude binary; using it directly." >&2
        fi
    fi
else
    echo "Warning: could not create ${CLAUDE_BIN_DIR}; using the image-owned Claude binary directly." >&2
fi

if [ ! -L "${CLAUDE_BIN}" ] || [ "$(readlink "${CLAUDE_BIN}")" != "${DEFAULT_CLAUDE_BIN}" ]; then
    CLAUDE_BIN="${DEFAULT_CLAUDE_BIN}"
fi

extra_args=()
has_mcp_config_arg=0
has_strict_mcp_config_arg=0

for arg in "$@"; do
    case "$arg" in
        --mcp-config|--mcp-config=*)
            has_mcp_config_arg=1
            ;;
        --strict-mcp-config)
            has_strict_mcp_config_arg=1
            ;;
    esac
done

if is_apptainer_runtime; then
    if [ "${has_strict_mcp_config_arg}" -eq 0 ]; then
        extra_args+=(--strict-mcp-config)
    fi
    if [ "${has_mcp_config_arg}" -eq 0 ]; then
        if [ -n "${BR_MCP_TOKEN:-}" ] && [ -f "${CLAUDE_DEFAULT_MCP_CONFIG}" ]; then
            extra_args+=(--mcp-config "${CLAUDE_DEFAULT_MCP_CONFIG}")
        else
            extra_args+=(--mcp-config '{"mcpServers":{}}')
        fi
    fi
elif [ "${has_mcp_config_arg}" -eq 0 ] && [ -n "${BR_MCP_TOKEN:-}" ] && [ -f "${CLAUDE_DEFAULT_MCP_CONFIG}" ]; then
    extra_args+=(--mcp-config "${CLAUDE_DEFAULT_MCP_CONFIG}")
fi

exec "${CLAUDE_BIN}" --allow-dangerously-skip-permissions "${extra_args[@]}" "$@"

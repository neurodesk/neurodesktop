    local sanitized_token

    sanitized_token=$(printf "%s" "${raw_token}" | tr -d '\000-\010\013\014\016-\037\177')
    sanitized_token="${sanitized_token//$'\r'/}"
    sanitized_token="${sanitized_token//$'\n'/}"
    sanitized_token=$(printf "%s" "${sanitized_token}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

    printf "%s" "${sanitized_token}"
}

load_br_mcp_token_from_bashrc() {
